  "category": "shell",
  "description": "Share information flow / screen (responsive exports).",
  "interactionStates": [
    "default"
  ],
  "assets": {
    "overview": "overview.png",
    "variants": {
      "desktop-default": {
        "default": "variants/desktop-default/default.svg"
      },
      "desktop-full-screen": {
        "default": "variants/desktop-full-screen/default.svg"
      },
      "mobile-default": {
        "default": "variants/mobile-default/default.svg"
      }
    }
  },
  "tokens": {
    "radius": "alias.radius.regular",
    "modes": {
      "light": {
        "foreground": "mapped/light.foreground.foreground"
      },
      "dark": {
        "foreground": "mapped/dark.foreground.foreground"
      }
    }
  },
  "notes": [
    "Each variant folder carries `default.png` (raster export) next to vector `default.svg`.",
    "`desktop-default` — ~640px modal-width frame; `desktop-full-screen` — wide desktop comp."
