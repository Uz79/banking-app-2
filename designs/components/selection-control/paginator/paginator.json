      "3-dots-mid-active": {
        "default": "variants/3-dots-mid-active/default.svg"
      },
      "3-dots-right-active": {
        "default": "variants/3-dots-right-active/default.svg"
      }
    }
  },
  "tokens": {
    "radius": "alias.radius.regular",
    "modes": {
      "light": {
        "foreground": "mapped/light.foreground.foreground"
      },
      "dark": {
        "foreground": "mapped/dark.foreground.foreground"
      }
