{
  "name": "account-picker",
  "category": "selection-control",
  "description": "Selection control for choosing an account (e.g. in transfer/payment flows).",
  "interactionStates": [
    "default",
    "hover",
    "focus"
  ],
  "assets": {
    "variants": {
      "default-default": {
        "focus": "variants/default-default/focus.svg",
        "default": "variants/default-default/default.svg",
        "hover": "variants/default-default/hover.svg",
        "pressed 2": "variants/default-default/pressed 2.svg",
        "pressed": "variants/default-default/pressed.svg"
      },
      "default-error": {
        "default": "variants/default-error/default.svg"
      },
      "default-informative": {
        "default": "variants/default-informative/default.svg"
      }
    }
  },
  "tokens": {
    "radius": "alias.radius.regular",
    "stroke": "mapped.border.border-secondary",
    "strokeFocus": "mapped.border.border",
    "modes": {
      "light": {
        "foreground": "mapped/light.foreground.foreground"
      },
      "dark": {
        "foreground": "mapped/dark.foreground.foreground"
      }
    }
  },
  "accessibility": {
    "needsAccessibleName": true,
    "keyboardFocusable": true
  },
  "notes": [
    "Figma exports `Pressed` are stored as `focus` for consistency.",
    "PNGs added 2026-06-01. Old loose Figma exports archived to _archive/2026-06-01/.",
    "Component structure: `.debit-account` > icon | .debit-account__info | .debit-account__end (.debit-account__amount [currency + value] + chevron)."
  ]
}
