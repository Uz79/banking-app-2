{
  "name": "segmented-control",
  "category": "selection-control",
  "description": "Selection control for switching between related views or modes.",
  "interactionStates": [
    "default",
    "hover",
    "focus"
  ],
  "assets": {
    "overview": "overview.png",
    "variants": {
      "regular-left-active": {
        "default": "variants/regular-left-active/default.svg"
      },
      "regular-right-active": {
        "default": "variants/regular-right-active/default.svg"
      }
    }
  },
  "tokens": {
    "radius": "alias.radius.regular",
    "modes": {
      "light": {
        "foreground": "mapped/light.foreground.foreground"
      },
      "dark": {
        "foreground": "mapped/dark.foreground.foreground"
      }
    }
  },
  "accessibility": {
    "needsAccessibleName": true,
    "keyboardFocusable": true
  },
  "notes": [
    "Figma exports `Pressed` are stored as `focus.svg` for consistency."
  ]
}
