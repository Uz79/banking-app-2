{
  "name": "segmented-control",
  "category": "selection-control",
  "description": "Selection control for switching between related views or modes.",
  "interactionStates": [
    "default",
    "hover",
    "focus"
  ],
  "assets": {
    "overview": "overview.png",
    "variants": {
      "regular-left-active": {
        "default": "variants/regular-left-active/default.svg"
      },
      "regular-right-active": {
        "default": "variants/regular-right-active/default.svg"
      },
      "small-left-active": {
        "default": "variants/small-left-active/default.svg"
      },
      "small-right-active": {
        "default": "variants/small-right-active/default.svg"
      }
    }
  },
  "tokens": {
    "radius": "alias.radius.regular",
    "modes": {
      "light": {
        "foreground": "mapped/light.foreground.foreground"
      },
      "dark": {
        "foreground": "mapped/dark.foreground.foreground"
      }
    }
  },
  "accessibility": {
    "needsAccessibleName": true,
    "keyboardFocusable": true
  },
  "notes": [
    "Figma Type=Regular → 44dp track; Type=Small → 36dp track (used in app toolbar / theme switch).",
    "Case=Left Active | Right Active — which segment is selected in the export snapshot.",
    "Figma exports `Pressed` are stored as `focus.svg` when present."
  ]
}
