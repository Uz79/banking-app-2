        "surface": "mapped/light.background.background-elevated"
      },
      "dark": {
        "foreground": "mapped/dark.foreground.foreground",
        "foregroundSecondary": "mapped/dark.foreground.foreground-disabled",
        "border": "mapped/dark.border.border-subtle",
        "surface": "mapped/dark.background.background-elevated"
      }
