{
  "name": "checkbox",
  "category": "selection-control",
  "description": "Selection control for toggling an independent boolean choice.",
  "interactionStates": [
    "default",
    "hover",
    "focus"
  ],
  "assets": {
    "overview": "overview.png",
    "variants": {
      "regular-active": {
        "default": "variants/regular-active/default.svg",
        "hover": "variants/regular-active/hover.svg",
        "focus": "variants/regular-active/focus.svg",
        "pressed": "variants/regular-active/pressed.svg"
      },
      "regular-inactive": {
        "default": "variants/regular-inactive/default.svg",
        "hover": "variants/regular-inactive/hover.svg",
        "focus": "variants/regular-inactive/focus.svg",
        "pressed": "variants/regular-inactive/pressed.svg"
      }
    }
  },
  "tokens": {
    "radius": "alias.radius.regular",
    "modes": {
      "light": {
        "foreground": "mapped/light.foreground.foreground"
      },
      "dark": {
        "foreground": "mapped/dark.foreground.foreground"
      }
    }
  },
  "accessibility": {
    "needsAccessibleName": true,
    "keyboardFocusable": true
  },
  "notes": [
    "Figma exports `Pressed` are stored as `focus.svg` for consistency."
  ]
}
